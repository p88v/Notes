<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_text_note_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/f_arround_note"
        android:ellipsize="end"
        android:layout_marginBottom="10dp"
        android:padding="24dp"
        android:paddingEnd="48dp"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="заметка о том как я ботаю андройд и хочу стать jun разрабочиком в этом году" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:button="@drawable/ic_vertical_dot"
        app:layout_constraintBottom_toBottomOf="@id/tv_text_note_title"
        app:layout_constraintEnd_toEndOf="@id/tv_text_note_title"
        app:layout_constraintTop_toTopOf="@id/tv_text_note_title" />

</androidx.constraintlayout.widget.ConstraintLayout>